{
  "compilerOptions": {
    /* === Rutas y salida === */
    "rootDir": "./src",
    "outDir": "./dist",

    /* === Compatibilidad con Node y módulos === */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* === Tipado y validaciones === */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* === Mapas y declaraciones === */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
