# ============================================================
# backend/.env  —  Fix ERR_EMPTY_RESPONSE
#
# ERRORES CORREGIDOS:
#   1. DB_HOST: dentro de Docker el hostname es el nombre del
#      servicio ('postgres'), no 'localhost'.
#      'localhost' dentro de un contenedor apunta al contenedor
#      mismo, no a PostgreSQL — causa que el backend crashee
#      al arrancar y no responda ningún request.
#
#   2. NODE_ENV=production: con este valor ts-node-dev no
#      transpila TypeScript correctamente en el contenedor de
#      desarrollo. Usar 'development' para el entorno Docker dev.
# ============================================================

# ── Base de Datos ─────────────────────────────────────────────
# ✅ FIX: 'postgres' = nombre del servicio en docker-compose.yml
DB_HOST=postgres
DB_PORT=5432
DB_NAME=restaurant_pwa
DB_USER=postgres
DB_PASSWORD=Tdea2024

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
# ✅ FIX: 'development' para que ts-node-dev transpile correctamente
NODE_ENV=development

# ── Seguridad ─────────────────────────────────────────────────
JWT_SECRET=cambiar-por-una-clave-segura-en-produccion
JWT_EXPIRY=24h

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Modo de operación ─────────────────────────────────────────
# Opciones: autoservicio | mesero | ambos
OPERATION_MODE=ambos